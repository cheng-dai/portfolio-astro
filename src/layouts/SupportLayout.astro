---
import BaseHead from "../components/BaseHead.astro";

interface Feature {
  title: string;
  description: string;
}

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  appName: string;
  tagline?: string;
  description: string;
  contactEmail: string;
  features?: Feature[];
  faq?: FAQItem[];
  privacy?: string;
}

const { appName, tagline, description, contactEmail, features, faq, privacy } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead />
    <title>{appName} - Support</title>
  </head>
  <body class="bg-[#ebe6de] font-sans min-h-screen text-black/80">
    <main class="max-w-3xl mx-auto px-8 md:px-12 py-16">

      <!-- Header -->
      <section class="mb-16">
        <h1 class="text-4xl font-bold tracking-tight mb-3">{appName}</h1>
        {tagline && <p class="text-xl text-black/50">{tagline}</p>}
        <p class="mt-4 text-black/70 leading-relaxed">{description}</p>
      </section>

      <!-- Features -->
      {features && features.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-semibold mb-6">Features</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {features.map((feature) => (
              <div class="border border-black/10 rounded-2xl p-5 bg-white/40">
                <h3 class="font-semibold mb-1">{feature.title}</h3>
                <p class="text-sm text-black/60 leading-relaxed">{feature.description}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- FAQ -->
      {faq && faq.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-semibold mb-6">Frequently Asked Questions</h2>
          <div class="space-y-4">
            {faq.map((item) => (
              <details class="group border border-black/10 rounded-2xl bg-white/40">
                <summary class="cursor-pointer p-5 font-medium flex items-center justify-between">
                  {item.question}
                  <span class="text-black/30 group-open:rotate-45 transition-transform text-xl leading-none">+</span>
                </summary>
                <p class="px-5 pb-5 text-sm text-black/60 leading-relaxed">{item.answer}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      <!-- Privacy -->
      {privacy && (
        <section class="mb-16">
          <h2 class="text-2xl font-semibold mb-4">Privacy</h2>
          <p class="text-black/70 leading-relaxed">{privacy}</p>
        </section>
      )}

      <!-- Contact -->
      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">Contact</h2>
        <p class="text-black/70">
          Need help? Reach out at
          <a href={`mailto:${contactEmail}`} class="underline underline-offset-2 hover:text-black/90 transition-colors">
            {contactEmail}
          </a>
        </p>
      </section>

      <!-- Back link -->
      <div class="pt-8 border-t border-black/10">
        <a href="/" class="text-sm text-black/40 hover:text-black/60 transition-colors">&larr; chengdai.dev</a>
      </div>

    </main>
  </body>
</html>
