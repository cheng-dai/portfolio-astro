---
import projectsData from "@/projects.json";
import booksData from "@/books.json";
const allProjects = projectsData.filter((project) => !project.archive);
const currentlyReading = booksData.filter((book) => book.status === "reading");
---

<div class="container">
  <!-- Registration marks -->
  <div class="reg-mark tl"></div>
  <div class="reg-mark tr"></div>
  <div class="reg-mark bl"></div>
  <div class="reg-mark br"></div>

  <!-- Header -->
  <header>
    <h1>Xucheng<br />Dai</h1>
    <span class="subtitle">Product Engineer</span>
  </header>

  <!-- Left sidebar: Bio + Contact -->
  <aside class="block sidebar-left" id="contact">
    <span class="mono-label">01 // Profile</span>
    <p class="bio-text-small">
      People call me Cheng. I'm a product engineer who enjoys turning shower thoughts into digital tools that solve real problems.
    </p>
    <div class="contact-list">
      <div class="contact-item">
        <span class="contact-label">Email</span>
        <a href="mailto:chengdai.dev@gmail.com">chengdai.dev@gmail.com</a>
      </div>
      <div class="contact-item">
        <span class="contact-label">GitHub</span>
        <a href="https://github.com/cheng-dai" target="_blank">@cheng-dai</a>
      </div>
      <div class="contact-item">
        <span class="contact-label">LinkedIn</span>
        <a href="https://www.linkedin.com/in/chengdai/" target="_blank">/in/chengdai</a>
      </div>
    </div>
  </aside>

  <!-- Center: Canvas + Projects -->
  <main class="block main-center">
    <div class="visual-accent">
      <canvas id="glcanvas"></canvas>
    </div>
    <div class="projects-area" id="projects">
      <span class="mono-label">02 // Projects</span>
      <div class="project-grid">
        {allProjects.map((project) => (
          <a href={project.url} target="_blank" class="project-card-link">
            <div class="project-card">
              <div class="project-name">{project.name}</div>
              <div class="project-desc">{project.shortDescription ?? project.description[0]}</div>
              </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <!-- Right sidebar: Now -->
  <aside class="block sidebar-right">
    <span class="mono-label">03 // Now</span>
    <div class="card-list">
      <div class="info-card">
        <span class="card-sub">Location</span>
        <span class="card-title">STOCKHOLM, SE</span>
      </div>
      <div class="info-card">
        <span class="card-sub">Running</span>
        <span class="card-title">STOCKHOLM HALF MARATHON</span>
        <span class="card-sub">Training for it</span>
      </div>
      {currentlyReading.map((book) => (
        <div class="info-card">
          <span class="card-sub">Reading</span>
          <span class="card-title">{book.title.toUpperCase()}</span>
          <span class="card-sub">{book.author}</span>
        </div>
      ))}
    </div>
  </aside>

  <!-- Footer -->
  <footer>
    <span>&copy; {new Date().getFullYear()} Xucheng Dai</span>
  </footer>
</div>

<style>
  .container {
    width: 100%;
    max-width: 1280px;
    background-color: var(--color-paper);
    border-radius: 20px;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-ink);
  }

  @media (min-width: 768px) {
    .container {
      grid-template-columns: 280px 1fr 280px;
      grid-template-rows: auto 1fr auto;
    }
  }

  @media (min-width: 1024px) {
    .container {
      grid-template-columns: 320px 1fr 320px;
    }
  }

  .block {
    padding: 24px;
    position: relative;
  }

  .mono-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 20px;
    display: block;
    opacity: 0.8;
  }

  /* Header */
  header {
    grid-column: 1 / -1;
    border-bottom: 1px solid var(--color-ink);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 40px 24px 24px 24px;
  }

  h1 {
    font-size: 48px;
    font-weight: 500;
    line-height: 0.85;
    margin: 0;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }

  @media (min-width: 768px) {
    h1 { font-size: 72px; }
  }

  @media (min-width: 1024px) {
    h1 { font-size: 80px; }
  }

  .subtitle {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.7;
    align-self: flex-end;
  }

  .header-nav {
    font-family: var(--font-mono);
    font-size: 12px;
    display: flex;
    gap: 20px;
  }

  .header-nav a {
    color: var(--color-ink);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .header-nav a:hover {
    opacity: 1;
  }

  /* Mobile order: bio first, then projects, then now */
  .sidebar-left { order: 1; }
  .main-center { order: 2; }
  .sidebar-right { order: 3; }
  footer { order: 4; }

  @media (min-width: 768px) {
    .sidebar-left { order: unset; }
    .main-center { order: unset; }
    .sidebar-right { order: unset; }
    footer { order: unset; }
  }

  /* Left sidebar */
  .sidebar-left {
    border-top: 1px solid var(--color-ink);
  }

  @media (min-width: 768px) {
    .sidebar-left {
      border-top: none;
    }
  }

  .bio-text-small {
    font-size: 15px;
    line-height: 1.5;
    margin: 0 0 24px;
  }

  .contact-list {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.8;
  }

  .contact-item {
    margin-bottom: 16px;
  }

  .contact-item:last-child {
    margin-bottom: 0;
  }

  .contact-label {
    display: block;
    font-size: 11px;
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-item a {
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .contact-item a:hover {
    border-bottom-color: var(--color-ink);
  }

  /* Center column */
  .main-center {
    border-top: 1px solid var(--color-ink);
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px) {
    .main-center {
      grid-column: 2;
      grid-row: 2;
      border-top: none;
      border-left: 1px solid var(--color-ink);
      border-right: 1px solid var(--color-ink);
    }
  }

  .visual-accent {
    position: relative;
    overflow: hidden;
    height: 200px;
    border-bottom: 1px solid var(--color-ink);
  }

  @media (min-width: 768px) {
    .visual-accent {
      height: 240px;
    }
  }

  canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .projects-area {
    padding: 24px;
  }

  .project-grid {
    display: grid;
    gap: 12px;
  }

  .project-card-link {
    text-decoration: none;
    color: var(--color-ink);
  }

  .project-card {
    border: 1px solid var(--color-ink);
    padding: 16px;
    transition: background-color 0.2s;
  }

  .project-card:hover {
    background-color: rgba(139, 58, 42, 0.08);
  }

  .project-name {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    margin-bottom: 6px;
    letter-spacing: 0.02em;
    font-weight: 700;
  }

  .project-desc {
    font-size: 13px;
    line-height: 1.4;
    margin-bottom: 6px;
  }

  .project-tech {
    font-family: var(--font-mono);
    font-size: 10px;
    opacity: 0.7;
  }

  /* Right sidebar */
  .sidebar-right {
    border-top: 1px solid var(--color-ink);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  @media (min-width: 768px) {
    .sidebar-right {
      border-top: none;
    }
  }

  .sidebar-section {
    padding-bottom: 20px;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--color-ink);
  }

  .sidebar-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .card-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .info-card {
    border: 1px solid var(--color-ink);
    padding: 12px;
    font-family: var(--font-mono);
  }

  .info-card-link {
    text-decoration: none;
    color: var(--color-ink);
    transition: background-color 0.2s;
    display: block;
  }

  .info-card-link:hover {
    background-color: rgba(139, 58, 42, 0.08);
  }

  .card-title {
    font-weight: 700;
    display: block;
    font-size: 13px;
  }

  .card-sub {
    font-size: 11px;
    opacity: 0.7;
  }

  /* Footer */
  footer {
    grid-column: 1 / -1;
    border-top: 1px solid var(--color-ink);
    padding: 16px 24px;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
  }

  /* Registration marks */
  .reg-mark {
    position: absolute;
    width: 10px;
    height: 10px;
    border: 1px solid var(--color-ink);
    z-index: 20;
    display: none;
  }

  @media (min-width: 768px) {
    .reg-mark { display: block; }
  }

  .tl { top: 10px; left: 10px; border-right: 0; border-bottom: 0; }
  .tr { top: 10px; right: 10px; border-left: 0; border-bottom: 0; }
  .bl { bottom: 10px; left: 10px; border-right: 0; border-top: 0; }
  .br { bottom: 10px; right: 10px; border-left: 0; border-top: 0; }
</style>

<script>
  const canvas = document.getElementById('glcanvas') as HTMLCanvasElement;
  if (canvas) {
    const gl = canvas.getContext('webgl');
    if (gl) {
      const vsSource = `attribute vec4 aVertexPosition; void main() { gl_Position = aVertexPosition; }`;
      const fsSource = `
        precision highp float;
        uniform vec2 u_resolution;
        uniform float u_time;

        float hash(vec2 p) {
          return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
        }

        float noise(vec2 p) {
          vec2 i = floor(p);
          vec2 f = fract(p);
          f = f * f * (3.0 - 2.0 * f);
          return mix(
            mix(hash(i), hash(i + vec2(1.0, 0.0)), f.x),
            mix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), f.x),
            f.y
          );
        }

        // 4x4 Bayer dither matrix
        float bayer4(vec2 p) {
          vec2 c = floor(mod(p, 4.0));
          int i = int(c.x) + int(c.y) * 4;
          if (i ==  0) return  0.0/16.0;
          if (i ==  1) return  8.0/16.0;
          if (i ==  2) return  2.0/16.0;
          if (i ==  3) return 10.0/16.0;
          if (i ==  4) return 12.0/16.0;
          if (i ==  5) return  4.0/16.0;
          if (i ==  6) return 14.0/16.0;
          if (i ==  7) return  6.0/16.0;
          if (i ==  8) return  3.0/16.0;
          if (i ==  9) return 11.0/16.0;
          if (i == 10) return  1.0/16.0;
          if (i == 11) return  9.0/16.0;
          if (i == 12) return 15.0/16.0;
          if (i == 13) return  7.0/16.0;
          if (i == 14) return 13.0/16.0;
          if (i == 15) return  5.0/16.0;
          return 0.0;
        }

        void main() {
          vec2 uv = gl_FragCoord.xy / u_resolution.xy;
          float t = u_time * 0.15;

          float n = noise(uv * 3.0 + t) * 0.5 + noise(uv * 6.0 - t * 0.7) * 0.3;
          n += sin(uv.x * 3.14 + t) * sin(uv.y * 2.0 - t * 0.5) * 0.2;

          float threshold = bayer4(gl_FragCoord.xy);
          float dithered = step(threshold, n);

          vec3 paper = vec3(200.0/255.0, 196.0/255.0, 188.0/255.0);
          vec3 ink = vec3(139.0/255.0, 58.0/255.0, 42.0/255.0);

          gl_FragColor = vec4(mix(paper, ink, dithered * 0.45), 1.0);
        }
      `;

      function createShader(gl: WebGLRenderingContext, type: number, source: string) {
        const shader = gl.createShader(type)!;
        gl.shaderSource(shader, source);
        gl.compileShader(shader);
        return shader;
      }

      const program = gl.createProgram()!;
      gl.attachShader(program, createShader(gl, gl.VERTEX_SHADER, vsSource));
      gl.attachShader(program, createShader(gl, gl.FRAGMENT_SHADER, fsSource));
      gl.linkProgram(program);
      gl.useProgram(program);

      const posBuffer = gl.createBuffer();
      gl.bindBuffer(gl.ARRAY_BUFFER, posBuffer);
      gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,1, 1,1, -1,-1, 1,-1]), gl.STATIC_DRAW);
      const posLoc = gl.getAttribLocation(program, "aVertexPosition");
      gl.enableVertexAttribArray(posLoc);
      gl.vertexAttribPointer(posLoc, 2, gl.FLOAT, false, 0, 0);

      const resLoc = gl.getUniformLocation(program, "u_resolution");
      const timeLoc = gl.getUniformLocation(program, "u_time");

      function render(time: number) {
        canvas.width = canvas.clientWidth;
        canvas.height = canvas.clientHeight;
        gl!.viewport(0, 0, canvas.width, canvas.height);
        gl!.uniform2f(resLoc, canvas.width, canvas.height);
        gl!.uniform1f(timeLoc, time * 0.001);
        gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
        requestAnimationFrame(render);
      }
      requestAnimationFrame(render);
    }
  }
</script>
